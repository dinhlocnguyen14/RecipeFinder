{
  "name": "recipe-finder-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:mobile\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:mobile": "cd mobile && npx expo start --go --lan",
    "dev:mobile:tunnel": "cd mobile && npx expo start --go --tunnel",
    "dev:mobile:reset": "cd mobile && npx expo start --clear",
    "install:all": "npm install && cd backend && npm install && cd ../mobile && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
